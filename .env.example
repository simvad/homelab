# Network Configuration
HOMELAB_IP=192.168.1.100           # IP address of your homelab server
HOMELAB_INTERFACE=eth0             # Network interface name
HOMELAB_PUBLIC_URL=http://homelab.local:8096  # Public URL for Jellyfin

# VM Configuration
WIN10_MEMORY=4                     # Memory allocation for Windows VM in GB
WIN10_CPUS=2                       # CPU cores for Windows VM

# Storage Configuration
MEDIA_PATH=/mnt/data/media         # Path to media storage
BOOKS_PATH=/mnt/data/books         # Path to books storage
CONFIG_PATH=/mnt/data/config       # Path to config storage
DEV_PATH=/mnt/data/dev             # Path to development storage
VM_PATH=/mnt/data/vm               # Path to VM storage
